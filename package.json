{
  "name": "devdoctor",
  "version": "0.1.0",
  "description": "A plugin-based CLI utility that diagnoses, explains, and safely repairs common development environment issues.",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "devdoctor": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "diagnostics",
    "developer-tools",
    "devops"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
